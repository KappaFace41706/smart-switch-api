{
  "name": "smart-switch-api",
  "version": "1.0.0",
  "description": "智慧開關管理系統後端 API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run tsoa:watch\" \"npm run serve:watch\"",
    "serve:watch": "nodemon --exec tsx src/index.ts",
    "tsoa:watch": "nodemon --watch src/controllers --watch src/interfaces --ext ts --exec \"tsoa spec-and-routes\"",
    "build": "tsoa spec-and-routes && tsc",
    "start": "node dist/index.js",
    "tsoa:gen": "tsoa spec-and-routes",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-ui-express": "^4.1.7",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}